# Solana RPC endpoint — public rate-limits aggressively, recommend Helius/QuickNode
RPC_URL=https://mainnet.helius-rpc.com/?api-key=<your-helius-api-key>

# Owner wallet — used by scripts/discoverPositions.ts to look up position pubkeys
POSITION_OWNER_PUBKEY=<your-wallet-public-key>

# Position account pubkeys — one per forward-test strategy.
# Run: npx ts-node scripts/discoverPositions.ts  to find your position pubkeys.
POSITION_PUBKEY_01=<base58-position-pubkey>

# POSITION_PUBKEY_02=
# POSITION_PUBKEY_03=
# POSITION_PUBKEY_04=
# POSITION_PUBKEY_05=
# POSITION_PUBKEY_06=

# Future: hedge exchange credentials (not used yet)
# HEDGE_EXCHANGE=none
# HEDGE_API_KEY=
# HEDGE_API_SECRET=

# ---------------------------------------------------------------------------
# Execution engine (autonomous rebalancing) — leave EXECUTION_ENABLED=false
# for read-only monitoring mode.
# ---------------------------------------------------------------------------

# Master switch — flip to true to enable autonomous rebalancing
EXECUTION_ENABLED=false

# Wallet private key — base58 (Phantom export) or JSON byte array (Solana CLI)
# WALLET_PRIVATE_KEY=<base58-or-json-array>

# Jupiter API base URL — lite tier (no API key required)
JUPITER_API_URL=https://lite-api.jup.ag/swap/v1

# Token required to call POST /api/kill (kill switch HTTP endpoint)
# KILL_SWITCH_TOKEN=<random-secret-string>

# Dashboard password — leave empty or unset for no password gate
# DASHBOARD_PASSWORD=<your-password>

# Transaction priority fee in microlamports (default: 50000)
PRIORITY_FEE_MICROLAMPORTS=50000

# Max slippage for Jupiter swaps in basis points (default: 50 = 0.5%)
MAX_SLIPPAGE_BPS=50

# Max slippage for Meteora deposits in basis points (default: 100 = 1%)
METEORA_SLIPPAGE_BPS=100

# Bins out-of-range before triggering a rebalance — raised from default 2 for first test
OUT_OF_RANGE_BIN_THRESHOLD=3

# Minimum time between rebalances in ms — raised from default 300000 (5 min) for first test
MIN_REBALANCE_INTERVAL_MS=600000

# Fees must be this multiple of tx cost before rebalancing — lowered from default 3.0 for $100 position
FEE_GATE_MULTIPLIER=2.0

# Bollinger width above which volatility cooldown activates (default: 0.02 = 2%)
VOLATILITY_COOLDOWN_THRESHOLD=0.02

# How long to pause after volatility spike clears in ms (default: 900000 = 15 min)
VOLATILITY_COOLDOWN_MS=900000

# Bin radius for new positions (bins on each side of active bin) — raised from default 10 for first test
DEFAULT_BIN_RADIUS=20
